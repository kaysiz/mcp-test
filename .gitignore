# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/

# UV / tooling
.python-version.bak
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# OS / editors
.DS_Store
.idea/
.vscode/
*.swp

# ---------------------------------------------------------------------------
# Real DataCite datafiles (NEVER commit — too large / user-supplied)
# Place downloads under data/local/ and set DATACITE_DATA_DIR to that folder.
# Keep data/local/README.md tracked as setup instructions only.
# ---------------------------------------------------------------------------
data/local/*
!data/local/README.md
data/public/
data/monthly/
data/raw/

# Loose / misplaced datafiles at repo root (safety net)
/*.jsonl
/*.jsonl.gz
/*-??.csv
/*-??.csv.gz
/part_*.jsonl
/part_*.jsonl.gz

# Bulk archives from datafiles.datacite.org
*.tar
*.tar.gz
!docs/**

# Exports generated by the MCP (optional; can be large)
exports/
**/exports/

# Env / secrets
.env
.env.*

# MCP / agent caches
.fastmcp/

# Local MCP host configs with absolute paths (example mcp.json may be committed)
mcp.local.json